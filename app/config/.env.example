# Copy this file to `.env` and fill in real values for your environment.
# `.env` itself is gitignored -- never commit real secrets.

# --- OCR ---
# Active OCR provider: "tesseract" | "azure_di"
OCR_PROVIDER=tesseract
# Explicit path to the Tesseract binary (optional -- falls back to PATH,
# then to typical per-OS install locations if left unset)
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Document conversion (Word -> PDF, etc.) ---
# Active document-converter provider: "com" | "azure"
DOC_CONVERTER_PROVIDER=com

# --- SQL Server (audit log) ---
SQLSERVER_HOST=localhost
SQLSERVER_DB=acrobat_tools_audit
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=changeme

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
